# OmniverseCORE environment example

APP_NAME="OmniverseCORE"
APP_ENV="development"
APP_VERSION="1.0.0"

# API
REST_HOST="0.0.0.0"
REST_PORT="8000"
GRAPHQL_PORT="8001"
GRPC_PORT="8002"

# Dashboard
DASHBOARD_HOST="0.0.0.0"
DASHBOARD_PORT="3000"

# Logging
LOG_LEVEL="INFO"

# AI
AI_ENABLED="true"
AI_DEFAULT_MODEL="local-gguf-small"
AI_USE_GPU="true"

# Database / Vector DB (optionnel)
VECTOR_DB_URL="http://localhost:6333"
VECTOR_DB_TYPE="qdrant"

# Security
ENABLE_AUTH="true"
JWT_SECRET="CHANGE_ME_IN_PRODUCTION"
